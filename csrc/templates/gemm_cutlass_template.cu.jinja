// =============================================================================
// GEMM launcher: D = A @ B [+ C]
// =============================================================================

void gemm(TensorView output, TensorView A, TensorView B, Optional C_opt,
          int64_t split_k_slices) {
    CHECK_INPUT(A);
    CHECK_INPUT(B);
    CHECK_INPUT(output);
    CHECK_DIM(2, A);
    CHECK_DIM(2, B);

    int M = A.size(0);
    int K = A.size(1);
    int N = B.size(0);

    cudaStream_t stream = get_stream(A.device());

    DISPATCH_DLPACK_HALF_DTYPE(A.dtype(), c_type, [&] {
        using CutlassType = typename ToCutlassType<c_type>::type;
        using LayoutA = cutlass::layout::RowMajor;
        using LayoutB = cutlass::layout::ColumnMajor;
        using LayoutC = cutlass::layout::RowMajor;

        const CutlassType* C_ptr = nullptr;
        if (C_opt.has_value()) {
            C_ptr = reinterpret_cast<const CutlassType*>(C_opt.value().data_ptr());
        }

        float alpha = 1.0f;
        uint64_t lda = K;
        uint64_t ldb = K;
        uint64_t ldc = N;

        auto status = oasr::gemm::CutlassGemmKernel<
            Config, MMA, CutlassType, CutlassType, CutlassType,
            LayoutA, LayoutB, LayoutC, oasr::EpilogueIdentity>::run(
                reinterpret_cast<const CutlassType*>(A.data_ptr()),
                reinterpret_cast<const CutlassType*>(B.data_ptr()),
                C_ptr,
                reinterpret_cast<CutlassType*>(output.data_ptr()),
                M, N, K, lda, ldb, ldc, alpha, stream,
                static_cast<int>(split_k_slices));
        TVM_FFI_ICHECK(status == oasr::gemm::GemmStatus::SUCCESS)
            << "GEMM kernel failed";
        return true;
    });
}

